# Environment Configuration for B2Study

# Flask Settings
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///b2study.db
# For production: postgresql://user:password@localhost/b2study

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,zip

# Session Configuration
PERMANENT_SESSION_LIFETIME=3600
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Export Configuration
EXPORT_FOLDER=exports
MAX_EXPORT_SIZE=10000

# Social Links (for footer)
INSTAGRAM_URL=https://instagram.com/your-handle
LINKEDIN_URL=https://linkedin.com/in/your-profile
GITHUB_URL=https://github.com/your-username
TWITTER_URL=https://twitter.com/your-handle
PORTFOLIO_URL=https://your-portfolio.com

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Pagination
ITEMS_PER_PAGE=12
